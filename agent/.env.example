# AI Providers
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
AI_PROVIDER=openai                        # claude | openai | ollama

# Model overrides (optional)
CLAUDE_MODEL=claude-opus-4-7
OPENAI_MODEL=gpt-4o

# Ollama (local testing — no API key needed)
# Start Ollama, pull a model, then set AI_PROVIDER=ollama
# ollama pull llama3.1         # recommended for tool use
# ollama pull qwen2.5:14b      # stronger reasoning, needs more RAM
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Google
# Tracker backend (pluggable storage). Leave blank to derive from GOOGLE_AUTH_MODE.
#   sheets      — Google Sheets via service account
#   apps_script — Google Apps Script web-app bridge
#   jsonfile    — local JSON file, no credentials (great for dev/test/demos)
TRACKER_BACKEND=
TRACKER_JSON_FILE=./data/tracker.json   # used only when TRACKER_BACKEND=jsonfile

# Knowledge-source backend: gdrive | apps_script | localfs. Blank = derive from
# GOOGLE_AUTH_MODE. localfs reads from SOURCE_LOCAL_DIR (no credentials).
SOURCE_BACKEND=
SOURCE_LOCAL_DIR=./data/sources

# Use apps_script if you cannot use Google Cloud service accounts.
GOOGLE_AUTH_MODE=apps_script

# Service account mode only
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# Apps Script mode only
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_APPS_SCRIPT_TOKEN=

CONTENTOPS_SHEET_ID=your_google_sheet_id_here
CONTENTOPS_SHEET_NAME=Content Tracker
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here  # folder with blogs, notes, transcripts

# Slack
# Bot Token: from your Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# App Token: from your Slack App → Basic Information → App-Level Tokens (connections:write scope)
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_REVIEW_CHANNEL=#contentops-review

# AuthZ (RBAC)
AUTHZ_FILE=./authz.yaml
AUTHZ_STRICT=true
AUTHZ_DEFAULT_ROLE=viewer
# Optional bootstrap admins by Slack user ID (comma-separated)
AUTHZ_ADMIN_USERS=

# Observability / tracking
# SQLite telemetry store. On Fly.io point this at a mounted volume (/data/ops.db).
CONTENTOPS_DB=./data/ops.db
# Logging: "text" (default, human-readable) or "json" (structured, for log shippers)
LOG_FORMAT=text
LOG_LEVEL=INFO

# Quality gate (deterministic checks before a draft reaches Slack)
QUALITY_GATE_ENABLED=true
QUALITY_MIN_VOICE_SCORE=8
QUALITY_MIN_CHARS=200
QUALITY_MAX_CHARS=3000

# Dashboard (interactive web interface — watch / review / edit / approve per RBAC)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
# Session signing key — set a stable random value in production (else sessions
# reset on restart). Generate: openssl rand -hex 32
DASHBOARD_SECRET_KEY=
# Public URL of the dashboard (used to build the Slack OAuth redirect). If blank,
# derived from the request. e.g. https://contentops.yourco.com
DASHBOARD_BASE_URL=

# Sign in with Slack (production identity). Create a Slack app, enable OpenID
# Connect, add redirect URL <DASHBOARD_BASE_URL>/auth/slack/callback, set these.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Dev login (Slack user id + token). "" = on only when Slack OAuth is NOT set;
# "true"/"false" to force. Used as the dev-login password when set.
DASHBOARD_DEV_LOGIN=
DASHBOARD_TOKEN=
