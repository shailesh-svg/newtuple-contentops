# AI Providers
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
AI_PROVIDER=claude                        # claude | openai

# Model overrides (optional)
CLAUDE_MODEL=claude-opus-4-7
OPENAI_MODEL=gpt-4o

# Google
# Use apps_script if you cannot use Google Cloud service accounts.
GOOGLE_AUTH_MODE=apps_script

# Service account mode only
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# Apps Script mode only
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_APPS_SCRIPT_TOKEN=

CONTENTOPS_SHEET_ID=your_google_sheet_id_here
CONTENTOPS_SHEET_NAME=Content Tracker
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here  # folder with blogs, notes, transcripts

# Slack
# Bot Token: from your Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# App Token: from your Slack App → Basic Information → App-Level Tokens (connections:write scope)
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_REVIEW_CHANNEL=#contentops-review

# AuthZ (RBAC)
AUTHZ_FILE=./authz.yaml
AUTHZ_STRICT=true
AUTHZ_DEFAULT_ROLE=viewer
# Optional bootstrap admins by Slack user ID (comma-separated)
AUTHZ_ADMIN_USERS=
